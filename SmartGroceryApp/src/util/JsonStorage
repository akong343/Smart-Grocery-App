package util;

import model.Ingredient;
import model.Recipe;
import model.GroceryItem;

import java.io.*;
import java.util.ArrayList;
import java.util.List;

/*
 recipes.txt format:
 recipeName
 ingredientName|qty|unit
 ingredientName|qty|unit
 ---
 Use similar simple formats for pantry.txt
*/
public class JsonStorage {
    public static void saveRecipes(List<Recipe> recipes, String path) {
        try (PrintWriter pw = new PrintWriter(new FileWriter(path))) {
            for (Recipe r : recipes) {
                pw.println(r.name);
                for (Ingredient ing : r.ingredients) {
                    pw.println(ing.name + "|" + ing.qty + "|" + ing.unit);
                }
                pw.println("---");
            }
        } catch (Exception e) { e.printStackTrace(); }
    }


// resturned list of recipes
    public static List<Recipe> loadRecipes(String path) { 
        List<Recipe> out = new ArrayList<>();
        File f = new File(path);
        if (!f.exists()) return out;
        try (BufferedReader br = new BufferedReader(new FileReader(f))) {
            String line;
            Recipe current = null;
            while ((line = br.readLine()) != null) {
                if (line.trim().isEmpty()) continue;
                if (line.equals("---")) {
                    if (current != null) { out.add(current); current = null; }
                    continue;
                }
                if (current == null) { current = new Recipe(line.trim()); continue; }
                // ingredient line
                String[] parts = line.split("\\|");
                if (parts.length >= 3) {
                    String name = parts[0];
                    double qty = Double.parseDouble(parts[1]);
                    String unit = parts[2];
                    current.addIngredient(new Ingredient(name, qty, unit));
                }
            }
            if (current != null) out.add(current);
        } catch (Exception e) { e.printStackTrace(); }
        return out;
    }
// pantry list of items 
    public static void savePantry(List<GroceryItem> list, String path) {
        try (PrintWriter pw = new PrintWriter(new FileWriter(path))) {
            for (GroceryItem g : list) {
                pw.println(g.name + "|" + g.qty + "|" + g.unit);
            }
        } catch (Exception e) { e.printStackTrace(); }
    }

    public static List<GroceryItem> loadPantry(String path) {
        List<GroceryItem> out = new ArrayList<>();
        File f = new File(path);
        if (!f.exists()) return out;
        try (BufferedReader br = new BufferedReader(new FileReader(f))) {
            String line;
            while ((line = br.readLine()) != null) {
                if (line.trim().isEmpty()) continue;
                String[] p = line.split("\\|");
                if (p.length >= 3) out.add(new GroceryItem(p[0], Double.parseDouble(p[1]), p[2]));
            }
        } catch (Exception e) { e.printStackTrace(); }
        return out;
    }
}
